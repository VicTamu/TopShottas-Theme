{%- liquid
  assign t404_title = 'templates.404.title' | t
  assign continue_label = 'general.continue_shopping' | t
-%}

<div class="template-404 page-width page-margin">
  {% render 'ts-empty-state',
    class: 'ts-empty--page',
    badge: 'Lost in the smoke',
    title: t404_title,
    text: 'The page you’re looking for drifted off. Let’s get you back to the drop.',
    button_label: continue_label,
    button_url: routes.all_products_collection_url
  %}
</div>
